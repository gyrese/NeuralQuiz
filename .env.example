# --- Secrets requis (le serveur refuse de démarrer sans eux) ---

# Mot de passe de l'interface admin (min. 8 caractères, choisir une valeur forte)
ADMIN_PASSWORD=

# Clé de signature des JWT (chaîne aléatoire longue, ex. `openssl rand -hex 32`)
JWT_SECRET=

# --- Configuration optionnelle ---

# Clé Google Maps (requise pour GeoTrackr / Street View)
GOOGLE_MAPS_API_KEY=

# Domaine servi par Caddy en production (ex. quiz.mondomaine.fr)
SITE_ADDRESS=localhost

# Email pour les certificats ACME / Let's Encrypt
ACME_EMAIL=your-email@example.com

# Origines autorisées pour CORS (séparées par des virgules). Laisser vide = tout autoriser (dev).
# ALLOWED_ORIGINS=https://quiz.mondomaine.fr
